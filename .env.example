# ============================================================
# demo-app Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to version control
# ============================================================

# --- Database (local Docker Postgres) ---
DATABASE_URL="postgresql://demo_user:demo_pass@localhost:5432/demo_db"

# --- API Server ---
PORT=3001
NODE_ENV=development
API_BASE_URL=http://localhost:3001

# --- Frontend (Vite) ---
VITE_API_BASE_URL=http://localhost:3001

# --- Error Monitoring (GlitchTip - Sentry-compatible) ---
# Sign up free at https://app.glitchtip.com or self-host
# Leave empty to disable error monitoring locally
GLITCHTIP_DSN=
VITE_GLITCHTIP_DSN=

# --- Auth (future) ---
JWT_SECRET=change_me_to_a_secure_random_string_min_32_chars
JWT_EXPIRY=7d

# --- CORS ---
CORS_ORIGINS=http://localhost:5173
