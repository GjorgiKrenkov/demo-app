{
  "name": "@demo-app/db",
  "version": "0.0.0",
  "private": true,
  "description": "Drizzle ORM schema, migrations, and database client",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "node --env-file=../../.env --import tsx/esm src/seed.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --max-warnings=0"
  },
  "dependencies": {
    "@demo-app/validators": "workspace:*",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.39.1",
    "drizzle-zod": "^0.8.3",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@demo-app/config": "workspace:*",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.10.7",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
